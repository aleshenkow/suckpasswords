# Copy this file to .env and adjust values for your environment
POSTGRES_DB=suckpasswords
POSTGRES_USER=suckpasswords
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

APP_SECRET_KEY=change_me_super_long_random_secret_key
APP_DATA_ENCRYPTION_KEY=change_me_32byte_or_longer_random_phrase
APP_ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_ADMIN_USERNAME=suckadmin
APP_ADMIN_PASSWORD=suckpassword
APP_ADMIN_EMAIL=suckadmin@local

# LDAP/AD settings
AD_ENABLED=false
AD_SERVER_URI=ldaps://ad.example.local:636
AD_BASE_DN=DC=example,DC=local
AD_BIND_DN=CN=svc-bind,OU=ServiceAccounts,DC=example,DC=local
AD_BIND_PASSWORD=change_me_bind_password
AD_USER_FILTER=(sAMAccountName={username})
AD_REQUIRED_GROUP_DN=CN=PasswordVaultUsers,OU=Groups,DC=example,DC=local

# Internal
DATABASE_URL=postgresql+psycopg://suckpasswords:change_me_db_password@db:5432/suckpasswords
